<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.praise.gmvmaxsync</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/macbook/claude/tools/shopee-quadrant/scripts/gmvmax-daily-sync.sh</string>
  </array>
  <!-- Jalan tiap hari 07:30 waktu lokal. Mac harus menyala/terjaga. -->
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>7</integer><key>Minute</key><integer>30</integer></dict>
  <key>StandardOutPath</key><string>/Users/macbook/claude/tools/shopee-quadrant/logs/gmvmax-launchd.out</string>
  <key>StandardErrorPath</key><string>/Users/macbook/claude/tools/shopee-quadrant/logs/gmvmax-launchd.err</string>
  <key>RunAtLoad</key><false/>
</dict>
</plist>
